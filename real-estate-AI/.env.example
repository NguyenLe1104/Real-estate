# ============ n8n ============
N8N_PORT=5678
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me
N8N_ENCRYPTION_KEY=replace_with_a_long_random_string
GENERIC_TIMEZONE=Asia/Ho_Chi_Minh

# ============ Local Model (Ollama) ============
OLLAMA_PORT=11434
DEFAULT_OLLAMA_MODEL=qwen2.5:7b

# ============ Vector Database (Qdrant) ============
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ============ Connect to existing real-estate stack ============
# This should match the Docker network from the main compose project.
# In this repository it is usually: real-estate_default
REAL_ESTATE_SHARED_NETWORK=real-estate_default

# Internal endpoint used by n8n to call NestJS API over Docker network.
REAL_ESTATE_API_BASE_URL=http://real-estate-backend:5000/api
