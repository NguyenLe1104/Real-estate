# ============ Database ============
MYSQL_ROOT_PASSWORD=your_mysql_password
MYSQL_DATABASE=real_estate_db
DB_PORT=3307

# ============ Backend ============
BE_PORT=5000
JWT_SECRET=your_jwt_secret
JWT_EXPIRES=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRES=7d
MAX_REFRESH_TOKENS_PER_USER=5

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============ Mail (Gmail SMTP) ============
# LƯU Ý VPS: Nhiều cloud provider block port 587 outbound.
# → Giải pháp 1: Dùng port 465 (SSL) + thêm secure=true trong mail.service.ts
# → Giải pháp 2: Dùng SendGrid/Mailgun thay Gmail SMTP
# → MAIL_PASSWORD phải là App Password (16 ký tự), KHÔNG phải mật khẩu Gmail thường
#   Tạo tại: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Gemini
GEMINI_API_KEY=your_gemini_api_key

# LLM Provider
LLM_PROVIDER=gemini
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK_1=gemini-flash-latest
GEMINI_MODEL_FALLBACK_2=gemini-2.5-flash-lite
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_MS=1200
GEMINI_THINKING_BUDGET=0
OLLAMA_TIMEOUT_MS=9000

# ============ RabbitMQ ============
# LƯU Ý: hostname "rabbitmq" là tên service trong docker-compose, KHÔNG phải localhost
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672?heartbeat=30
RABBITMQ_RECONNECT_SECONDS=5
RABBITMQ_CONNECTION_TIMEOUT_MS=30000

# ============ Frontend / URLs ============
FE_PORT=3000
# Thay YOUR_VPS_IP bằng IP thực hoặc domain của VPS
FRONTEND_URL=http://YOUR_VPS_IP:3000
VITE_API_BASE_URL=http://YOUR_VPS_IP:5000/api
VITE_GOOGLE_CLIENT_ID=your_google_client_id
