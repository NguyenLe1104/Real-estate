# Database
DATABASE_URL="mysql://root:password@localhost:3306/real_estate_db"

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRES=7d
MAX_REFRESH_TOKENS_PER_USER=5

# Server
PORT=5000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# RabbitMQ
RABBITMQ_URL=amqp://localhost:5672

# VNPay
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:5000/api/payment/vnpay/callback

# MoMo
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:5000/api/payment/momo/callback
MOMO_NOTIFY_URL=http://localhost:5000/api/payment/momo/notify

# Frontend URL (for payment redirect)
FRONTEND_URL=http://localhost:3000

# Redis Cache
REDIS_URL=redis://localhost:6379

# RAG AI
OLLAMA_URL=http://localhost:11434
QDRANT_URL=http://localhost:6333
GEMINI_API_KEY=your_gemini_api_key
LLM_PROVIDER=gemini
GEMINI_MODEL_PRIMARY=gemini-2.5-flash
GEMINI_MODEL_FALLBACK_1=gemini-flash-latest
GEMINI_MODEL_FALLBACK_2=gemini-2.5-flash-lite
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_MS=1200
GEMINI_THINKING_BUDGET=0
RAG_COLLECTION=real_estate_rag
CHAT_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
RAG_TOP_K=4
RAG_CONTEXT_K=2
RAG_MIN_SCORE=0.2
EMBED_CONCURRENCY=8
RAG_HISTORY_TURNS=2
RAG_HISTORY_MAX_TURNS=20
RAG_HISTORY_SUMMARY_CHARS=1000
RAG_CANDIDATE_MULTIPLIER=8
RAG_DESCRIPTION_CHARS=80
CHAT_NUM_PREDICT=256
EMBED_QUERY_CACHE_TTL=600
RAG_RESPONSE_CACHE_TTL=120
RAG_ENABLE_LLM=true
RAG_FAST_MODE=true
OLLAMA_TIMEOUT_MS=9000
QDRANT_TIMEOUT_MS=2500
EMBED_TIMEOUT_MS=5000
RAG_LOG_TIMINGS=true
