{
  "name": "real-estate",
  "private": true,
  "description": "Dự án gồm API (NestJS) và frontend (Vite). Chạy npm install trong từng thư mục con.",
  "scripts": {
    "install:api": "npm install --prefix real-estate-api",
    "install:web": "npm install --prefix real-estate-frontend",
    "install:all": "npm run install:api && npm run install:web"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.3.8",
    "@nestjs/microservices": "^11.1.17",
    "ioredis": "^5.10.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0"
  }
}